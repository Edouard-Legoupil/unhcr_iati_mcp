{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "unhcr-iati": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "unhcr_iati_mcp.server"
      ],
      "enabled": true,
      "env": {
        "IATI_API_KEY": "{env:IATI_API_KEY}",
        "MCP_TRANSPORT": "stdio"
      }
    }
  }
}
